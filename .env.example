# ── Server ───────────────────────────────────────
PORT=3000

# ── Library ──────────────────────────────────────
# Windows:  LIBRARY_ROOT=D:\Books
# Linux:    LIBRARY_ROOT=/mnt/books
# Docker:   LIBRARY_ROOT=/library  (mount your books folder to /library)
LIBRARY_ROOT=/library

# Optional: override .inpx path (otherwise set in admin panel)
# INPX_FILE=/library/catalog.inpx

# ── Multiple sources (Docker) ────────────────────
# Mount additional book folders via docker-compose volumes:
#   - /host/path/epub:/sources/epub:ro
#   - /host/path/pdf:/sources/pdf:ro
# Then add them in admin panel: Sources → Add → type "Folder", path "/sources/epub"

# ── Auth ─────────────────────────────────────────
# При первом запуске создаётся admin с паролем admin.
# Смените пароль в профиле после первого входа.
#
# SESSION_SECRET — секрет подписи cookie-сессий (вход в сайт). Необязательно:
# если не задать или оставить слабый placeholder, сервер создаст data/.session-secret.
# Для Docker с постоянным томом data/ обычно ничего указывать не нужно.
# Для фиксированного секрета: openssl rand -hex 32
# SESSION_SECRET=

# Дублировать события (как в админке «События») в stdout — удобно для docker logs
# EVENTS_STDOUT=true
# SESSION_SECURE_COOKIE=false
# SESSION_MAX_AGE_MS=1209600000
# LOGIN_WINDOW_MS=900000
# LOGIN_MAX_ATTEMPTS=10

# Задержка (мс) перед post-index WAL checkpoint и ANALYZE после окончания индексации.
# Даёт HTTP время обработать очередь; на очень больших БД ANALYZE всё равно долгий, но идёт по таблицам с уступкой циклу.
# POST_INDEX_MAINTENANCE_DELAY_MS=2000

# Минимальный ответ /health без порта и лишних полей (мониторинг в открытой сети)
# HEALTH_MINIMAL=false

# ── Reverse proxy ────────────────────────────────
# TRUST_PROXY=false
#
# Полный чеклист для продакшена: см. DEPLOY.md в корне репозитория.

# ── FB2 converter (auto-detected in ./converter) ─
# FB2CNG_PATH=/app/converter/fbc
# FB2CNG_CONFIG_PATH=/app/converter/fb2cng.yaml

# ── 7-Zip (.7z archives; optional) ───────────────
# По умолчанию используется 7za из npm-пакета 7zip-bin.
# SEVEN_ZIP_PATH=C:\Program Files\7-Zip\7z.exe
# SEVEN_ZIP_PATH=/usr/bin/7z

# Макс. параллельных 7z-процессов (по умолчанию: 6)
# SEVEN_Z_MAX_CONCURRENT=6

# Макс. размер очереди 7z-операций (по умолчанию: 50)
# SEVEN_Z_MAX_QUEUE=50

# ── Таймауты архивов ───────────────────────────
# Таймаут открытия ZIP-архива в мс (по умолчанию: 120000 = 2 мин)
# ARCHIVE_ZIP_OPEN_TIMEOUT_MS=120000

# Таймаут получения списка файлов из 7z в мс (по умолчанию: 1500000 = 25 мин)
# SEVEN_Z_LIST_TIMEOUT_MS=1500000

# Таймаут извлечения файла из 7z в мс (по умолчанию: 900000 = 15 мин)
# SEVEN_Z_EXTRACT_TIMEOUT_MS=900000

# ── SMTP (send to e-reader) ─────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Cover thumbnails ─────────────────────────────
# COVER_MAX_WIDTH=220
# COVER_MAX_HEIGHT=320
# COVER_QUALITY=86
# Обработка обложек через sharp/libvips (ресайз/конвертация в webp).
# По умолчанию авто: на CPU без SSE4.2 (напр. Intel Atom Cedarview) отключается,
# чтобы libvips не уронил процесс сигналом SIGILL. Обложки тогда отдаются как есть.
# Принудительно: COVER_PROCESSING=1 (включить) / COVER_PROCESSING=0 (выключить).
# COVER_PROCESSING=

# ── Scan scheduler ───────────────────────────────
# Периодическая инкрементальная индексация каждые N часов (0 = выключено)
# SCAN_INTERVAL_HOURS=0

# ── Batch download / convert workers ─────────────
# Количество воркеров пакетного скачивания (по умолчанию: 12)
# BATCH_DOWNLOAD_WORKERS=12

# Количество воркеров пакетной конвертации (по умолчанию: 4)
# BATCH_CONVERT_WORKERS=4

# ── Cluster (многопроцессный режим) ───────────
# Количество воркеров (0 или не задано = однопроцессный режим).
# Каждый воркер обрабатывает запросы параллельно; индексация и state синхронизируются через БД.
# Рекомендуется: количество CPU-ядер (но не более 8 для NAS/RPi).
# CLUSTER_WORKERS=4

# ── Performance (автоопределение по RAM) ──────
# Профиль: авто (RAM <= 2 ГБ → embedded), или принудительно 'default' / 'embedded'.
# embedded: меньше кэш SQLite, отключен mmap, меньше потоков. Для NAS/ARM устройств.
# PERF_PROFILE=

# SQLite page cache в МБ (авто: 256 / 64 для embedded)
# SQLITE_CACHE_SIZE_MB=

# SQLite memory-mapped I/O в МБ (авто: 256 / 0 для embedded)
# SQLITE_MMAP_SIZE_MB=

# ── Telegram Bot ─────────────────────────────────
# Получить токен у @BotFather: /newbot
# TELEGRAM_BOT_TOKEN=123456789:AAxxxxxx...
#
# Список Telegram user ID через запятую (оставьте пустым — доступ у всех).
# Узнать свой ID: напишите @userinfobot в Telegram.
# TELEGRAM_ALLOWED_USERS=123456789,987654321
#
# Webhook (опционально; без URL — long polling):
# TELEGRAM_WEBHOOK_URL=https://your-domain.example/telegram/webhook
# или базовый URL + путь:
# TELEGRAM_WEBHOOK_BASE=https://your-domain.example
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=случайная_строка